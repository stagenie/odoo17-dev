<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Bouton header sur product.template form -->
    <record id="product_template_form_label_button" model="ir.ui.view">
        <field name="name">product.template.form.label.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[1]" position="before">
                <button name="action_print_label"
                        type="object"
                        class="btn-warning"
                        icon="fa-print"
                        string="Imprimer Étiquette"/>
            </xpath>
        </field>
    </record>

</odoo>
