<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_product_label">
        <t t-call="web.html_container">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-foreach="docs" t-as="product">
                <t t-set="barcode_b64" t-value="product._get_barcode_base64()"/>
                <div class="page" style="width: 40mm; height: 20mm; padding: 1mm; box-sizing: border-box; overflow: hidden; font-family: Arial, Helvetica, sans-serif; margin: 0;">

                    <!-- Barcode -->
                    <div style="text-align: center; margin-bottom: 0.5mm;">
                        <t t-if="barcode_b64">
                            <img t-attf-src="data:image/png;base64,{{barcode_b64}}"
                                 style="width: 36mm; height: 5.5mm;"
                                 alt="Barcode"/>
                        </t>
                        <t t-else="">
                            <div style="height: 5.5mm; font-size: 5pt; color: #999; line-height: 5.5mm;">Pas de code-barres</div>
                        </t>
                    </div>

                    <!-- Product Name -->
                    <div style="font-size: 5pt; font-weight: bold; line-height: 1.2; text-align: center; margin-bottom: 0.3mm; overflow: hidden; max-height: 7mm; word-wrap: break-word;">
                        <t t-esc="product.name"/>
                    </div>

                    <!-- Bottom line: default_code (left) + price (right) -->
                    <div style="display: flex; justify-content: space-between; align-items: baseline;">
                        <div style="font-size: 4.5pt; color: #555;">
                            <t t-esc="product.default_code or ''"/>
                        </div>
                        <div style="font-size: 7pt; font-weight: bold; text-align: right;">
                            <t t-esc="'%.2f' % product.lst_price"/> DA
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
