<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit sale order form to customize order lines tree -->
    <record id="view_order_form_inherit_line_display" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.line.display</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add line number after sequence handle -->
            <xpath expr="//field[@name='order_line']//tree//field[@name='sequence']" position="after">
                <field name="line_number" string="N°" readonly="1"
                       class="text-center" width="30px"/>
            </xpath>

            <!-- Add product name field after product_template_id -->
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_template_id']" position="after">
                <field name="product_name_only" string="Produit"
                       optional="show" readonly="1"/>
            </xpath>

            <!-- Hide description field by default -->
            <xpath expr="//field[@name='order_line']//tree//field[@name='name']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>


</odoo>
