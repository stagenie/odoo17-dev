<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleticket_enhanced">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: 'Courier New'; font-size: 9px; width: 80mm; padding: 0; margin: 0; margin-top: -10px; line-height: 1.1;">
                    <!-- En-tete avec logo -->
                    <div style="text-align: center; border-bottom: 1px dashed #ccc; margin-bottom: 3px; padding: 0 0 2px 0;">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-width: 150px; margin: 0; padding: 0;"/>
                        <div t-field="res_company.name" style="margin: 1px 0; font-size: 10px; font-weight: bold;"/>
                        <div style="font-size: 7px; line-height: 1.1;">
                            <span t-field="res_company.street"/> - <span t-field="res_company.city"/>
                        </div>
                        <div style="font-size: 7px;">Tel: <span t-field="res_company.phone"/></div>
                    </div>

                    <!-- Informations de la commande -->
                    <div style="margin-bottom: 8px; font-size: 9px;">
                        <div style="margin-bottom: 2px;">Cmd N° <span t-field="o.name"/></div>
                        <div style="margin-bottom: 2px;">Date: <span t-field="o.date_order"/></div>
                        <div>Client: <span t-field="o.partner_id.name"/></div>
                    </div>

                    <!-- Lignes de commande avec N° de ligne -->
                    <table style="width: 100%; margin-bottom: 8px; border-collapse: collapse; font-size: 9px; table-layout: fixed;">
                        <thead>
                            <tr style="border-bottom: 1px solid #000;">
                                <th style="padding: 1px 1px; width: 7%; text-align: center;">N°</th>
                                <th style="padding: 1px 2px; width: 47%; text-align: left;">Article</th>
                                <th style="padding: 1px 1px; width: 8%; text-align: right;">Qté</th>
                                <th style="padding: 1px 1px; width: 18%; text-align: right;">PU</th>
                                <th style="padding: 1px 1px; width: 20%; text-align: right;">Montant</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.order_line" t-as="line" style="border-bottom: 1px dotted #ccc; line-height: 1.0;">
                                <td style="padding: 1px 1px; text-align: center;">
                                    <span t-esc="line_index + 1"/>
                                </td>
                                <td style="padding: 1px 2px; max-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <span t-field="line.product_id.name"/>
                                </td>
                                <td style="padding: 1px 1px; text-align: right;">
                                    <span t-field="line.product_uom_qty" t-options='{"widget": "integer"}'/>
                                </td>
                                <td style="padding: 1px 1px; text-align: right;">
                                    <span t-field="line.price_unit" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td style="padding: 1px 1px; text-align: right;">
                                    <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Total -->
                    <div style="border-top: 1px dashed #000; padding-top: 5px; margin-top: 5px;">
                        <div style="font-weight: bold; font-size: 11px; display: flex; justify-content: space-between;">
                            <span>Total:</span>
                            <span t-field="o.amount_total" t-options='{"widget": "float", "precision": 2}'/>
                        </div>
                    </div>

                    <!-- Pied de page -->
                    <div style="text-align: center; margin-top: 10px; border-top: 1px dashed #ccc; padding-top: 5px; font-size: 8px;">
                        <p style="margin: 2px 0;">Merci de votre confiance !</p>
                        <p style="margin: 2px 0;">A bientot</p>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
