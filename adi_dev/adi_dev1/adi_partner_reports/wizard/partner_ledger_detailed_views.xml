<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="partner_ledger_detailed_view" model="ir.ui.view">
        <field name="name">Grand Livre Détaillé Partenaire</field>
        <field name="model">account.report.partner.ledger.detailed</field>
        <field name="inherit_id" ref="accounting_pdf_reports.account_common_report_view"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='journal_ids']" position="before">
                    <field name="partner_ids" widget="many2many_tags"
                           options="{'no_open': True, 'no_create': True}"/>
                </xpath>
                <xpath expr="//field[@name='target_move']" position="after">
                    <field name="result_selection"/>
                    <field name="amount_currency" groups="base.group_multi_currency"/>
                    <newline/>
                    <field name="reconciled"/>
                    <newline/>
                </xpath>
            </data>
        </field>
    </record>

    <record id="action_partner_ledger_detailed_menu" model="ir.actions.act_window">
        <field name="name">Grand Livre Détaillé</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.report.partner.ledger.detailed</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="partner_ledger_detailed_view"/>
        <field name="target">new</field>
    </record>

</odoo>
