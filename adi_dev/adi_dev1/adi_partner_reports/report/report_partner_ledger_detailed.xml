<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_partner_ledger_detailed">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <t t-set="data_report_margin_top" t-value="12"/>
                <t t-set="data_report_header_spacing" t-value="9"/>
                <t t-set="data_report_dpi" t-value="110"/>
                <div class="page">
                    <h2>Grand Livre Partenaire Détaillé</h2>
                    <div class="row mb-3">
                        <div class="col-3">
                            <strong>Société :</strong>
                            <p t-esc="res_company.name"/>
                        </div>
                        <div class="col-3">
                            <t t-if="data['form']['date_from']">
                                <strong>Du :</strong>
                                <span t-esc="data['form']['date_from']"/>
                                <br/>
                            </t>
                            <t t-if="data['form']['date_to']">
                                <strong>Au :</strong>
                                <span t-esc="data['form']['date_to']"/>
                            </t>
                        </div>
                        <div class="col-3">
                            <strong>Écritures :</strong>
                            <p t-if="data['form']['target_move'] == 'all'">Toutes les écritures</p>
                            <p t-if="data['form']['target_move'] == 'posted'">Comptabilisées uniquement</p>
                        </div>
                    </div>

                    <table class="table table-sm table-reports">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>JRNL</th>
                                <th>Compte</th>
                                <th>Référence</th>
                                <th class="text-end">Débit</th>
                                <th class="text-end">Crédit</th>
                                <th class="text-end">Solde</th>
                                <th t-if="data['form']['amount_currency']" class="text-end">Devise</th>
                            </tr>
                        </thead>
                        <t t-foreach="docs" t-as="o">
                            <tbody>
                                <!-- Partner summary row -->
                                <tr style="background-color: #e9ecef; font-weight: bold;">
                                    <td colspan="4">
                                        <span t-esc="o.ref"/>
                                        <t t-if="o.ref"> - </t>
                                        <span t-esc="o.name"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="sum_partner(data, o, 'debit')"
                                              t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="sum_partner(data, o, 'credit')"
                                              t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="sum_partner(data, o, 'debit - credit')"
                                              t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                    </td>
                                    <td t-if="data['form']['amount_currency']"/>
                                </tr>
                                <!-- Journal entry lines for this partner -->
                                <t t-foreach="lines(data, o)" t-as="line">
                                    <tr>
                                        <td>
                                            <span t-esc="line['date']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['code']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['a_code']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['displayed_name']"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="line['debit']"
                                                  t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="line['credit']"
                                                  t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="line['progress']"
                                                  t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                        </td>
                                        <td class="text-end" t-if="data['form']['amount_currency']">
                                            <t t-if="line['currency_id']">
                                                <span t-esc="line['amount_currency']"
                                                      t-options="{'widget': 'monetary', 'display_currency': line['currency_id']}"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <!-- Invoice detail lines (products) -->
                                    <t t-set="invoice_lines" t-value="get_invoice_lines(line['move_id'])"/>
                                    <t t-if="invoice_lines">
                                        <tr>
                                            <td colspan="3"/>
                                            <td t-att-colspan="data['form']['amount_currency'] and 5 or 4">
                                                <table class="table table-sm mb-0" style="font-size: 0.85em; background-color: #f8f9fa;">
                                                    <thead>
                                                        <tr>
                                                            <th>Produit</th>
                                                            <th class="text-end">Qté</th>
                                                            <th>Unité</th>
                                                            <th class="text-end">Prix Unit.</th>
                                                            <th class="text-end">Montant</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-foreach="invoice_lines" t-as="inv_line">
                                                            <tr>
                                                                <td t-esc="inv_line['product_name'] or ''"/>
                                                                <td class="text-end" t-esc="inv_line['quantity']"
                                                                    t-options="{'widget': 'float', 'precision': 2}"/>
                                                                <td t-esc="inv_line['product_uom'] or ''"/>
                                                                <td class="text-end">
                                                                    <span t-esc="inv_line['price_unit']"
                                                                          t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                                                </td>
                                                                <td class="text-end">
                                                                    <span t-esc="inv_line['price_subtotal']"
                                                                          t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </t>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
